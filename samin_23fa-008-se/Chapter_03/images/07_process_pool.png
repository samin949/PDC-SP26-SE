<svg viewBox="0 0 860 280" xmlns="http://www.w3.org/2000/svg" font-family="'Courier New', monospace">
  <defs>
    <linearGradient id="bg7" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#06080f"/>
      <stop offset="100%" style="stop-color:#0c1120"/>
    </linearGradient>
    <marker id="arr7" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#34d399"/>
    </marker>
    <marker id="arr7b" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#38bdf8"/>
    </marker>
  </defs>
  <rect width="860" height="280" fill="url(#bg7)" rx="12"/>
  <rect width="860" height="280" fill="none" stroke="#1a2540" stroke-width="1" rx="12"/>

  <text x="40" y="38" fill="#f97316" font-size="9" letter-spacing="4" font-weight="700">PROCESS POOL — pool.map() DISTRIBUTION</text>
  <line x1="40" y1="48" x2="820" y2="48" stroke="#1a2540" stroke-width="1"/>

  <!-- Input -->
  <rect x="40" y="100" width="130" height="80" fill="#101828" stroke="#38bdf8" stroke-width="1.5" rx="8"/>
  <text x="105" y="124" fill="#38bdf8" font-size="10" font-weight="700" text-anchor="middle">Input</text>
  <text x="105" y="142" fill="#e2e8f0" font-size="9" text-anchor="middle">list(range(100))</text>
  <text x="105" y="158" fill="#64748b" font-size="8" text-anchor="middle">100 integers: 0–99</text>
  <text x="105" y="172" fill="#64748b" font-size="8" text-anchor="middle">function_square</text>

  <!-- Arrow to pool -->
  <line x1="172" y1="140" x2="214" y2="140" stroke="#38bdf8" stroke-width="1.5" marker-end="url(#arr7b)"/>

  <!-- Pool box -->
  <rect x="216" y="88" width="130" height="104" fill="rgba(249,115,22,0.06)" stroke="#f97316" stroke-width="1.5" rx="8"/>
  <text x="281" y="112" fill="#f97316" font-size="10" font-weight="700" text-anchor="middle">Pool(processes=4)</text>
  <text x="281" y="130" fill="#64748b" font-size="9" text-anchor="middle">splits work</text>
  <text x="281" y="148" fill="#64748b" font-size="9" text-anchor="middle">automatically</text>
  <text x="281" y="166" fill="#f97316" font-size="8" text-anchor="middle">pool.map()</text>
  <text x="281" y="182" fill="#64748b" font-size="8" text-anchor="middle">dispatches tasks</text>

  <!-- Arrows to workers -->
  <line x1="348" y1="108" x2="396" y2="96" stroke="#f97316" stroke-width="1.5" marker-end="url(#arr7)"/>
  <line x1="348" y1="124" x2="396" y2="132" stroke="#f97316" stroke-width="1.5" marker-end="url(#arr7)"/>
  <line x1="348" y1="156" x2="396" y2="156" stroke="#f97316" stroke-width="1.5" marker-end="url(#arr7)"/>
  <line x1="348" y1="172" x2="396" y2="192" stroke="#f97316" stroke-width="1.5" marker-end="url(#arr7)"/>

  <!-- Workers -->
  <rect x="398" y="68" width="160" height="36" fill="#101828" stroke="#34d399" stroke-width="1.5" rx="6"/>
  <text x="478" y="83" fill="#34d399" font-size="9" font-weight="700" text-anchor="middle">Worker 1</text>
  <text x="478" y="97" fill="#64748b" font-size="8" text-anchor="middle">squares 0, 4, 8, 12 ...</text>

  <rect x="398" y="114" width="160" height="36" fill="#101828" stroke="#34d399" stroke-width="1.5" rx="6"/>
  <text x="478" y="129" fill="#34d399" font-size="9" font-weight="700" text-anchor="middle">Worker 2</text>
  <text x="478" y="143" fill="#64748b" font-size="8" text-anchor="middle">squares 1, 5, 9, 13 ...</text>

  <rect x="398" y="138" width="160" height="36" fill="#101828" stroke="#34d399" stroke-width="1.5" rx="6"/>
  <text x="478" y="153" fill="#34d399" font-size="9" font-weight="700" text-anchor="middle">Worker 3</text>
  <text x="478" y="167" fill="#64748b" font-size="8" text-anchor="middle">squares 2, 6, 10, 14 ...</text>

  <rect x="398" y="174" width="160" height="36" fill="#101828" stroke="#34d399" stroke-width="1.5" rx="6"/>
  <text x="478" y="189" fill="#34d399" font-size="9" font-weight="700" text-anchor="middle">Worker 4</text>
  <text x="478" y="203" fill="#64748b" font-size="8" text-anchor="middle">squares 3, 7, 11, 15 ...</text>

  <!-- Arrows to output -->
  <line x1="560" y1="86" x2="602" y2="106" stroke="#34d399" stroke-width="1.5" marker-end="url(#arr7)"/>
  <line x1="560" y1="132" x2="602" y2="126" stroke="#34d399" stroke-width="1.5" marker-end="url(#arr7)"/>
  <line x1="560" y1="156" x2="602" y2="150" stroke="#34d399" stroke-width="1.5" marker-end="url(#arr7)"/>
  <line x1="560" y1="192" x2="602" y2="172" stroke="#34d399" stroke-width="1.5" marker-end="url(#arr7)"/>

  <!-- Output -->
  <rect x="604" y="88" width="210" height="104" fill="#101828" stroke="#38bdf8" stroke-width="1.5" rx="8"/>
  <text x="709" y="112" fill="#38bdf8" font-size="10" font-weight="700" text-anchor="middle">pool_outputs</text>
  <text x="709" y="130" fill="#64748b" font-size="8" text-anchor="middle">Ordered results collected</text>
  <text x="709" y="150" fill="#e2e8f0" font-size="9" font-weight="700" text-anchor="middle">[0, 1, 4, 9, 16, 25 ...]</text>
  <text x="709" y="168" fill="#e2e8f0" font-size="9" font-weight="700" text-anchor="middle">[... 9801]</text>
  <text x="709" y="185" fill="#34d399" font-size="8" text-anchor="middle">100 results · in original order</text>

  <!-- Note -->
  <rect x="40" y="210" width="820" height="40" fill="rgba(52,211,153,0.04)" stroke="#1a2540" rx="6"/>
  <text x="450" y="228" fill="#34d399" font-size="9" text-anchor="middle">💡  pool.map() splits work automatically · collects results in order · even if workers finish at different times</text>
  <text x="450" y="244" fill="#64748b" font-size="9" text-anchor="middle">pool.close() prevents new tasks · pool.join() waits for all workers to finish</text>
</svg>
